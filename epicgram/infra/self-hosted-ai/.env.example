# DEEPINSIDE Self-Hosted AI Stack — local env template (PHASE S).
# Copy to .env and fill with LOCAL-ONLY values. Do NOT commit .env. No real production secrets here.
# These are infrastructure credentials for your own local containers, not Telegram/API keys.

# --- PostgreSQL ---
POSTGRES_USER=deepinside
POSTGRES_PASSWORD=change_me_local
POSTGRES_DB=deepinside_ai

# --- n8n ---
N8N_ENCRYPTION_KEY=change_me_local_random_32+
N8N_USER_MANAGEMENT_JWT_SECRET=change_me_local_random_32+

# --- MinIO (object storage) ---
MINIO_ROOT_USER=deepinside
MINIO_ROOT_PASSWORD=change_me_local

# --- AI Router: external providers are OPTIONAL and DISABLED by default. ---
# Leave blank to keep them in Mock/Disabled mode. Fill ONLY locally if you opt in.
# The DEEPINSIDE UI never reads or displays these values.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROK_API_KEY=
OPENROUTER_API_KEY=
