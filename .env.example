# EPIC☠️GRAM local configuration template.
# Copy to .env.local and fill in real values. .env.local is gitignored — never
# commit real api_id / api_hash / bot token / keys.

# --- Web / API wiring ---
NEXT_PUBLIC_TELEGRAM_WEBAPP_ENABLED=false
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
EPICGRAM_API_BASE_URL=http://127.0.0.1:8788

# --- EPIC☠STAR pet-project promo banner (UI/link only, no auto-messaging) ---
# Vite reads VITE_*-prefixed vars at build time. Override to point the banner at
# your real site / bot. Defaults: https://epicstar.fun and bot "EpicStarBot".
VITE_EPICSTAR_URL=https://epicstar.fun
VITE_EPICSTAR_BOT=EpicStarBot

# --- Telegram credentials (OWNER must provide) ---
# Official user-account API credentials from https://my.telegram.org -> API development tools.
# Used by the TDLib runtime for QR / phone login of the owner's OWN account.
TELEGRAM_API_ID=replace-with-official-api-id
TELEGRAM_API_HASH=replace-with-official-api-hash
# Optional: token of a bot YOU own (https://t.me/BotFather). Only needed if you
# add a Bot-API path later; the current TDLib client login does NOT require it.
TELEGRAM_BOT_TOKEN=replace-with-owned-bot-token

# --- Operator (owner) identity ---
EPICGRAM_OPERATOR_EMAIL=buchmanchik@gmail.com
# Optional local scrypt hash to enable operator password verification.
# Generate with: npm run operator:hash
EPICGRAM_OPERATOR_PASSWORD_SCRYPT=replace-with-local-scrypt-hash

# --- TDLib runtime ---
EPICGRAM_TDLIB_ENABLED=false
# Optional: override TDLib local state directory. On WSL/Linux the default is
# ~/.local/state/epicgram/tdlib to avoid fragile Windows-mounted project paths.
# EPICGRAM_TDLIB_ROOT=/home/user/.local/state/epicgram/tdlib
# Local at-rest encryption key for the TDLib session database (any long random string).
EPICGRAM_TDLIB_DATABASE_KEY=replace-with-local-encryption-key

# --- AI brain (EPIC☠STAR persona) ---
EPICGRAM_AI_ENABLED=false
# "epicstar-brain" = self-hosted OpenAI-compatible proxy (e.g. Ollama). For a
# self-hosted brain no platform key is required.
EPICGRAM_AI_PROVIDER=epicstar-brain
# Full OpenAI-compatible chat-completions URL of the brain.
EPICGRAM_AI_BASE_URL=http://localhost:8096/v1/chat/completions
EPICGRAM_OPENAI_MODEL=gemma2:9b
# Any non-empty value for a keyless local brain; a real key for a cloud provider.
EPICGRAM_AI_API_KEY=local-brain-no-key
# Outbound safety mode. Keep "operator_approval_required": the AI only drafts,
# and a human must click Send. Do NOT set to auto_send unless you intend the AI
# to send without approval.
EPICGRAM_AI_SEND_MODE=operator_approval_required

# Cloud OpenAI fallback (only if EPICGRAM_AI_PROVIDER=openai)
# OPENAI_API_KEY=replace-with-openai-platform-api-key
